# ============================================================================
# Phoenix Engine V2.0 - Git Ignore Rules
# ============================================================================

# Environment and Secrets
.env
*.env
!.env.example
.env.local
.env.*.local

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST
*.log

# Virtual Environments
venv/
ENV/
env/
.venv

# IDE and Editor Files
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
*.code-workspace

# Jupyter Notebooks
.ipynb_checkpoints
*.ipynb

# Database
*.db
*.sqlite
*.sqlite3

# Docker Volumes (persisted locally)
postgres_data/
pgadmin_data/

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
.pytest_cache/
.coverage
htmlcov/
.tox/
.hypothesis/

# Data Files (optional - uncomment if you want to exclude CSV data)
# data/*.csv
# !data/master_company_list.csv

# Temporary Files
tmp/
temp/
*.tmp
*.bak
*.swp

# OS Files
Thumbs.db
.DS_Store
Desktop.ini